// UNI STORE ERP
// Valores monetários são armazenados em centavos (Int).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer, porta 6543 no Supabase)
  directUrl = env("DIRECT_URL") // conexão direta (porta 5432) para migrações
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())

  movimentacoes MovimentacaoEstoque[]
  vendas        Venda[]
}

model Setor {
  id     String  @id @default(cuid())
  nome   String  @unique
  regiao String?
  ativo  Boolean @default(true)

  congregacoes Congregacao[]
}

model Congregacao {
  id      String  @id @default(cuid())
  nome    String
  lider   String // Nome do Líder de Jovens
  ativo   Boolean @default(true)
  setorId String
  setor   Setor   @relation(fields: [setorId], references: [id])

  clientes Cliente[]
  vendas   Venda[]
  reservas Reserva[]

  @@unique([nome, setorId])
}

model Cliente {
  id            String       @id @default(cuid())
  cpf           String?      @unique // somente dígitos; opcional
  nome          String
  telefone      String?
  congregacaoId String?
  congregacao   Congregacao? @relation(fields: [congregacaoId], references: [id])
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  vendas Venda[]
}

/// Modelo de peça (ex: "Camiseta Conferência 2026"), com arte para identificação visual.
model Modelo {
  id           String   @id @default(cuid())
  nome         String   @unique
  descricao    String?
  arquivoUrl   String? // arte no Supabase Storage
  arquivoNome  String?
  arquivoTipo  String? // image/png, application/pdf ...
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  produtos    Produto[]
  pedidoItens PedidoProducaoItem[]
}

model Produto {
  id              String   @id @default(cuid())
  modeloId        String
  modelo          Modelo   @relation(fields: [modeloId], references: [id])
  cor             String
  tamanho         String
  precoVenda      Int // centavos
  custoReferencia Int? // centavos
  descricao       String?
  estoqueAtual    Int      @default(0) // cache; fonte de verdade é MovimentacaoEstoque
  // Peças presas por reservas em aberto. Disponível = estoqueAtual - estoqueReservado.
  estoqueReservado Int     @default(0)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  movimentacoes MovimentacaoEstoque[]
  vendaItens    VendaItem[]
  reservaItens  ReservaItem[]
  eventoProdutos EventoProduto[]

  @@unique([modeloId, cor, tamanho])
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE_ENTRADA
  AJUSTE_SAIDA
}

enum OrigemMovimentacao {
  PRODUCAO // entrada vinda da fábrica
  VENDA
  EDICAO_VENDA
  EXCLUSAO_VENDA
  AJUSTE_MANUAL
  RETIRADA_RESERVA
  CANCELAMENTO_RESERVA
  VENDA_RESERVA // saída gerada pela retirada de uma reserva
}

model MovimentacaoEstoque {
  id            String             @id @default(cuid())
  produtoId     String
  produto       Produto            @relation(fields: [produtoId], references: [id])
  tipo          TipoMovimentacao
  origem        OrigemMovimentacao
  quantidade    Int // sempre positiva; o tipo define o sinal
  custoUnitario Int? // centavos; obrigatório em entradas de produção
  data          DateTime           @default(now())
  observacao    String?
  vendaId       String?
  venda         Venda?             @relation(fields: [vendaId], references: [id], onDelete: SetNull)
  pedidoId      String?
  pedido        PedidoProducao?    @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  usuarioId     String?
  usuario       Usuario?           @relation(fields: [usuarioId], references: [id])
  criadoEm      DateTime           @default(now())

  @@index([produtoId, data])
}

enum FormaPagamento {
  CARTAO
  PIX
  DINHEIRO
}

enum StatusEvento {
  PLANEJADO
  ATIVO
  ENCERRADO
}

/// Evento (vigília, conferência, Copa...). Agrupa vendas, reservas e produção.
model Evento {
  id            String       @id @default(cuid())
  nome          String
  slug          String       @unique // usado no link público de reserva
  descricao     String?
  local         String?
  dataInicio    DateTime
  dataFim       DateTime?
  prazoReserva  DateTime? // depois disso o link público fecha
  status        StatusEvento @default(PLANEJADO)
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  vendas   Venda[]
  reservas Reserva[]
  pedidos  PedidoProducao[]
  produtos EventoProduto[]
}

model Venda {
  id             String         @id @default(cuid())
  clienteId      String?
  cliente        Cliente?       @relation(fields: [clienteId], references: [id])
  clienteNome    String // sempre preenchido (único campo obrigatório do cliente)
  congregacaoId  String?
  congregacao    Congregacao?   @relation(fields: [congregacaoId], references: [id])
  liderNome      String?
  eventoId       String?
  evento         Evento?        @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  formaPagamento FormaPagamento
  total          Int // centavos
  lucroTotal     Int? // centavos; null = "não calculado"
  observacoes    String?
  data           DateTime       @default(now())
  usuarioId      String?
  usuario        Usuario?       @relation(fields: [usuarioId], references: [id])
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  itens         VendaItem[]
  movimentacoes MovimentacaoEstoque[]
  pagamentos    VendaPagamento[]
  reserva       Reserva?

  @@index([data])
}

model VendaItem {
  id            String  @id @default(cuid())
  vendaId       String
  venda         Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Int // centavos; snapshot do preço na venda
  custoUnitario Int? // centavos; snapshot do custo médio na venda

  @@index([produtoId])
}

enum StatusReserva {
  RESERVADA
  RETIRADA
  CANCELADA
  INADIMPLENTE // não veio buscar; as peças voltam a ficar disponíveis
}

/// Reserva feita pelo cliente no link público do evento; baixa o estoque só na retirada.
model Reserva {
  id             String          @id @default(cuid())
  codigo         String          @unique // ex: R-0042
  nome           String
  telefone       String
  cpf            String?
  congregacaoId  String?
  congregacao    Congregacao?    @relation(fields: [congregacaoId], references: [id])
  eventoId       String
  evento         Evento          @relation(fields: [eventoId], references: [id])
  formaPagamento FormaPagamento? // pretendida; a efetiva vai na venda gerada
  status         StatusReserva   @default(RESERVADA)
  observacoes    String?
  dataReserva    DateTime        @default(now())
  dataRetirada   DateTime?
  vendaId        String?         @unique // venda gerada na retirada
  venda          Venda?          @relation(fields: [vendaId], references: [id], onDelete: SetNull)

  itens ReservaItem[]

  @@index([eventoId, status])
}

model ReservaItem {
  id            String  @id @default(cuid())
  reservaId     String
  reserva       Reserva @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Int // centavos; snapshot no momento da reserva

  @@index([reservaId])
}

/// Produtos oferecidos no link público de reserva de um evento.
model EventoProduto {
  id        String  @id @default(cuid())
  eventoId  String
  evento    Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([eventoId, produtoId])
}

/// Permite dividir o pagamento (parte dinheiro, parte cartão, parte Pix).
model VendaPagamento {
  id      String         @id @default(cuid())
  vendaId String
  venda   Venda          @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  forma   FormaPagamento
  valor   Int // centavos

  @@index([vendaId])
}

enum StatusPedidoProducao {
  ENCOMENDADO
  RECEBIDO_PARCIAL
  RECEBIDO
  CANCELADO
}

/// Pedido de fabricação enviado ao fornecedor; ao confirmar recebimento vira estoque.
model PedidoProducao {
  id                  String               @id @default(cuid())
  identificacao       String // ex: "Lote Conferência 2026"
  fornecedor          String?
  eventoId            String?
  evento              Evento?              @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  dataPedido          DateTime
  dataPrevisaoEntrega DateTime
  dataRecebimento     DateTime?
  precoPorPeca        Int // centavos
  precoVendaSugerido  Int? // centavos; usado ao criar SKUs novas no recebimento
  arteUrl             String? // arte no Supabase Storage
  arteNome            String?
  arteTipo            String?
  status              StatusPedidoProducao @default(ENCOMENDADO)
  observacoes         String?
  criadoEm            DateTime             @default(now())
  atualizadoEm        DateTime             @updatedAt

  itens         PedidoProducaoItem[]
  movimentacoes MovimentacaoEstoque[]

  @@index([status, dataPrevisaoEntrega])
}

model PedidoProducaoItem {
  id                 String         @id @default(cuid())
  pedidoId           String
  pedido             PedidoProducao @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  modeloId           String
  modelo             Modelo         @relation(fields: [modeloId], references: [id])
  cor                String
  tamanho            String
  quantidadePedida   Int
  quantidadeRecebida Int            @default(0)

  @@index([pedidoId])
}
